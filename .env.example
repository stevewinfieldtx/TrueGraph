# Azure AD App Registration (client credentials flow)
# Grant: Mail.Read (Application), User.Read.All (Application)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-client-secret

# Public URL of THIS service on Railway + /webhook
# Set this AFTER your first Railway deploy so you know the domain
NOTIFICATION_URL=https://truegraph-production.up.railway.app/webhook

# Shared secret — any string. Graph returns it in every notification.
WEBHOOK_CLIENT_STATE=truegraph-v1-change-me

# CPA service already on Railway
CPA_BASE_URL=https://your-cpa.up.railway.app
CPA_API_KEY=
CPA_TENANT_ID=default

# Railway injects this automatically when you attach a Postgres plugin
DATABASE_URL=postgresql://user:pass@host:port/db

# Operating mode: shadow | warn | enforce
MODE=shadow

# p_authentic below this threshold = flagged
FLAG_THRESHOLD=0.55
