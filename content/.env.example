# ── TrueGraph (knowledge-graph / atom-selection service) ──────────────
# Canonical port: 8300  (8400 TDE, 8500 Orchestrator, 8600 TrueArtifact, 8700 CPA)
PORT=8300

# OpenRouter (for LLM cluster insight generation)
# Optional — if not set, insights are skipped and graph data still returns
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANALYSIS_MODEL=qwen/qwen-2.5-72b-instruct

# API auth (RECOMMENDED in production): when set, all routes except /health
# require the x-api-key header. Leave blank for open local dev.
TRUEGRAPH_API_KEY=

# Win/loss outcome intelligence (ported from the retired CPP-Engine):
# contacts, deal outcomes, /api/match verdicts.
# Railway Postgres. Unset = outcome endpoints 503, graph compute unaffected.
DATABASE_URL=

# CPA (the profile-building authority). /api/match fetches the contact's
# CPP-S from GET {CPA_URL}/profiles/s/{email} — fail-open when unset.
CPA_URL=
CPA_API_KEY=
